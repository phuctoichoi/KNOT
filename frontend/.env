# API Base URL - points to the backend /api/v1 domain
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket URL - points to the live notification / streaming port
VITE_WS_URL=ws://localhost:8000/ws/connect

# Map Tile Server URL - sets the base map layer template (OpenStreetMap)
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
