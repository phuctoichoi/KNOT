# ============================================================
# KNOT Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis Configuration  
REDIS_PASSWORD=your_secure_redis_password_here

# Application Security
SECRET_KEY=your_64_character_secret_key_generate_with_openssl_rand_hex_32

# MinIO Object Storage
MINIO_ACCESS_KEY=your_minio_access_key_min_3_chars
MINIO_SECRET_KEY=your_minio_secret_key_min_8_chars

# Email Configuration (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_EMAIL=your_email@gmail.com

# Frontend Configuration
FRONTEND_URL=http://localhost
FRONTEND_WS_URL=ws://localhost

# ============================================================
# Production Example Values (DO NOT USE IN PRODUCTION):
# POSTGRES_PASSWORD=KnotSecureDB2024!
# REDIS_PASSWORD=KnotRedis2024!
# SECRET_KEY=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456
# MINIO_ACCESS_KEY=knotminio
# MINIO_SECRET_KEY=KnotMinIO2024!
# ============================================================